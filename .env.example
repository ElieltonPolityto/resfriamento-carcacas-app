# Copie este arquivo para .env e preencha com os valores reais.
# O .env NÃO deve ser versionado.

# Host e porta do supervisório Carel Boss
CAREL_HOST=192.168.0.1
CAREL_PORT=8080

# Credenciais de acesso
CAREL_USERNAME=seu_usuario
CAREL_PASSWORD=sua_senha

# Identificadores do relatório (conforme configurado no Carel Boss)
CAREL_REPORT_ID=158
CAREL_FREQUENCY=3
